# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Auth (JWT)  — generate a strong secret:  openssl rand -base64 48
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL + pgvector). Matches docker-compose.yml.
# DIRECT_URL is only needed in production against a pooled provider (e.g. Neon):
# point DATABASE_URL at the pooled connection string and DIRECT_URL at the
# direct one so `prisma migrate` bypasses the pooler. Locally both can be the
# same single Postgres instance.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mockinterview?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/mockinterview?schema=public

# ─────────────────────────────────────────────────────────────────────────────
# Groq (LLM) — https://console.groq.com/keys   (free tier)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# ─────────────────────────────────────────────────────────────────────────────
# Deepgram (streaming STT) — optional. If unset, the browser SpeechRecognition
# fallback is used automatically. Key stays server-side; the client fetches a
# short-lived token from /api/voice/token.   https://console.deepgram.com
# ─────────────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# ─────────────────────────────────────────────────────────────────────────────
# Cartesia (TTS) — optional. If unset, the browser speechSynthesis fallback is
# used. Audio is proxied through /api/voice/tts so the key stays server-side.
# https://play.cartesia.ai
# ─────────────────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
CARTESIA_VOICE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings — local, no API key. BAAI/bge-small-en-v1.5 (384-dim) via fastembed.
# The model (~90MB) downloads once to the cache dir below on first use.
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_CACHE_DIR=./local_cache
